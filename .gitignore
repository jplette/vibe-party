# --- Environment & secrets ---
.env
.env.local
.env.*.local

# --- Go ---
backend/vendor/
backend/*.exe
backend/*.test
backend/server
backend/bin/
backend/tmp/

# --- Frontend ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/e2e-report/

# --- Frontend Radix ---
frontend-radix/node_modules/
frontend-radix/dist/
frontend-radix/.vite/
frontend-radix/coverage/
frontend-radix/e2e-report/

# --- Docker ---
postgres_data/
redis_data/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- Playwright MCP ---
.playwright-mcp/
