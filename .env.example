# =============================================================================
# Vibe-Party — Environment Variables Example
# Copy this file to .env and fill in your values
# =============================================================================

# --- Backend ---
DATABASE_URL=postgres://vibe:vibe_secret@localhost:5432/vibe_party?sslmode=disable
REDIS_URL=redis://localhost:6379
KEYCLOAK_ISSUER=http://localhost:8180/realms/vibe-party
KEYCLOAK_CLIENT_ID=vibe-party-frontend
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@vibe-party.local
APP_PORT=8080
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_OIDC_AUTHORITY=http://localhost:8180/realms/vibe-party
VITE_OIDC_CLIENT_ID=vibe-party-frontend
